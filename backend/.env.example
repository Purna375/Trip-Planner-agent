# Groq API Key (required for LangChain agent - get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenRouteService API Key (free tier available at https://openrouteservice.org/)
# Note: If not provided, will use Haversine formula for distance calculations
OPENROUTE_API_KEY=your_api_key

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500